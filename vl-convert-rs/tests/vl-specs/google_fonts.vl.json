{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {"url": "https://raw.githubusercontent.com/vega/vega-datasets/next/data/barley.json"},
  "mark": "bar",
  "encoding": {
    "x": {"aggregate": "sum", "field": "yield"},
    "y": {"field": "variety"},
    "color": {"field": "site"}
  },
  "title": "Fontsource Font Test",
  "config": {
    "axis": {"labelFont": "Lugrasimo", "titleFont": "Lugrasimo"},
    "legend": {"labelFont": "Lugrasimo", "titleFont": "Lugrasimo"},
    "title": {"font": "Bangers"}
  }
}
